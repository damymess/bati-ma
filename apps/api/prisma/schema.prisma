generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tables existantes en BDD (introspectées) ──────────────────────────────

model ArchitectProfile {
  id                       String    @id @default(cuid())
  name                     String
  email                    String    @unique
  phone                    String?
  license_number           String?
  professional_body        String    @default("Ordre des Architectes du Maroc")
  years_experience         Int       @default(0)
  specialties              Json      @default("[]")
  regions                  Json      @default("[]")
  languages                Json      @default("[\"Français\"]")
  description              String?
  portfolio_images         Json      @default("[]")
  website                  String?
  hourly_rate              Int?
  project_rate_min         Int?
  project_rate_max         Int?
  verified                 Boolean   @default(false)
  premium                  Boolean   @default(false)
  is_active                Boolean   @default(true)
  rating                   Float     @default(0) @db.Real
  review_count             Int       @default(0)
  password_hash            String?
  subscription_tier        String    @default("free")
  subscription_expires_at  DateTime? @db.Timestamptz(6)
  contacts_used_this_month Int       @default(0)
  contacts_limit           Int       @default(0)
  contacts_reset_at        DateTime? @db.Timestamptz(6)
  created_at               DateTime  @default(now()) @db.Timestamptz(6)
  updated_at               DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at               DateTime? @db.Timestamptz(6)

  contact_unlocks ContactUnlock[]

  @@map("architect_profile")
}

model ProjectRequest {
  id                   String    @id @default(cuid())
  client_name          String
  client_email         String
  client_phone         String?
  architect_profile_id String?
  title                String
  description          String    @default("")
  project_type         String
  location             String
  address              String?
  budget_min           Int?
  budget_max           Int?
  timeline             String?
  status               String    @default("submitted")
  architect_response   String?
  proposed_fee         Int?
  is_public            Boolean   @default(false)
  images               Json      @default("{}")
  responses_count      Int       @default(0)
  source               String    @default("website")

  // Lead quality tiering (modèle Habitatpresto / MyBuilder)
  lead_type            String    @default("cold") // cold | warm | hot | exclusive
  financing            String?   // cash | credit | mre | undecided
  calculator_payload   Json?     // snapshot des params calculateur pour audit
  last_engagement_at   DateTime? @db.Timestamptz(6) // dernier email re-engagement envoyé
  engagement_count     Int       @default(0)

  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at           DateTime? @db.Timestamptz(6)

  contact_unlocks ContactUnlock[]
  lead_purchases  LeadPurchase[]

  @@index([lead_type, status])
  @@map("project_request")
}

// ─── Lead Purchase (modèle Habitatpresto — achat de leads par architectes) ───

model LeadPurchase {
  id                   String   @id @default(cuid())
  architect_profile_id String
  project_request_id   String
  lead_type            String   // cold | warm | hot | exclusive
  credits_spent        Int      // 1 pour cold, 2 warm, 3 hot, 5 exclusive
  price_paid_mad       Int      // Prix payé pour ce lead
  unlock_level         String   @default("full") // partial | full (partial = preview only)
  created_at           DateTime @default(now()) @db.Timestamptz(6)

  project ProjectRequest @relation(fields: [project_request_id], references: [id])

  @@unique([architect_profile_id, project_request_id])
  @@index([project_request_id])
  @@index([architect_profile_id])
  @@map("lead_purchase")
}

// ─── Tables à créer ─────────────────────────────────────────────────────────

model ClientProfile {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String?
  city          String?
  password_hash String?
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at    DateTime? @db.Timestamptz(6)

  @@map("client_profile")
}

model ContactUnlock {
  id                   String   @id @default(cuid())
  architect_profile_id String
  project_request_id   String
  unlocked_at          DateTime @default(now()) @db.Timestamptz(6)
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  architect ArchitectProfile @relation(fields: [architect_profile_id], references: [id])
  project   ProjectRequest   @relation(fields: [project_request_id], references: [id])

  @@unique([architect_profile_id, project_request_id])
  @@map("contact_unlock")
}

model ForumThread {
  id            String    @id @default(cuid())
  author_id     String?
  author_name   String
  author_role   String?
  title         String
  content       String
  category      String
  views         Int       @default(0)
  replies_count Int       @default(0)
  pinned        Boolean   @default(false)
  locked        Boolean   @default(false)
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at    DateTime? @db.Timestamptz(6)

  replies ForumReply[]

  @@map("forum_thread")
}

model ForumReply {
  id          String    @id @default(cuid())
  thread_id   String
  author_id   String?
  author_name String
  author_role String?
  content     String
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at  DateTime? @db.Timestamptz(6)

  thread ForumThread @relation(fields: [thread_id], references: [id])

  @@map("forum_reply")
}

model PasswordReset {
  id         String   @id @default(cuid())
  token      String   @unique
  email      String
  role       String   // "architect" | "client"
  expires_at DateTime @db.Timestamptz(6)
  used       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("password_reset")
}

model AppelOffre {
  id           String    @id @default(cuid())
  title        String
  description  String    @default("")
  organism     String
  city         String
  reference    String?
  type         String
  sector       String
  budget       String?
  deadline     String
  publish_date String
  source       String    @default("marchespublics.gov.ma")
  source_url   String?
  status       String    @default("Ouvert")
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at   DateTime? @db.Timestamptz(6)

  @@map("appel_offre")
}

// ─── Reviews (Avis clients vérifiés) ────────────────────────────────────────

model Review {
  id                   String    @id @default(cuid())
  architect_profile_id String
  project_request_id   String?   // Lien optionnel vers projet (preuve achat)
  client_name          String
  client_email         String
  rating               Int       // 1-5
  title                String?
  comment              String
  photos               Json      @default("[]") // URLs photos avant/après
  status               String    @default("pending") // pending | approved | rejected
  admin_note           String?
  is_verified          Boolean   @default(false) // True si lié à un projet accepté
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at           DateTime? @db.Timestamptz(6)

  @@index([architect_profile_id, status])
  @@map("review")
}

// ─── Verification Documents (Badge Vérifié bati.ma) ─────────────────────────

model VerificationDocument {
  id                   String    @id @default(cuid())
  architect_profile_id String
  document_type        String    // patente | oam | cnss | assurance | cin | rc
  document_url         String    // URL upload
  status               String    @default("pending") // pending | approved | rejected
  admin_note           String?
  reviewed_at          DateTime? @db.Timestamptz(6)
  reviewed_by          String?
  expires_at           DateTime? @db.Timestamptz(6) // certaines pièces expirent (CNSS)
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([architect_profile_id, status])
  @@map("verification_document")
}

// ─── Subscription (Stripe / CMI tracking) ───────────────────────────────────

model Subscription {
  id                      String    @id @default(cuid())
  architect_profile_id    String    @unique
  tier                    String    // essentiel | pro | elite
  billing_cycle           String    @default("monthly") // monthly | annual
  provider                String    @default("stripe") // stripe | cmi | manual
  provider_subscription_id String?   @unique // Stripe sub ID or CMI ref
  provider_customer_id    String?
  status                  String    @default("incomplete") // active | past_due | canceled | incomplete | trialing
  current_period_start    DateTime? @db.Timestamptz(6)
  current_period_end      DateTime? @db.Timestamptz(6)
  cancel_at_period_end    Boolean   @default(false)
  amount_mad              Int       // montant en MAD (centimes pour Stripe)
  metadata                Json      @default("{}")
  created_at              DateTime  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("subscription")
}

// ─── Shortlist Credits (modèle MyBuilder — achat de leads à l'unité) ────────

model ShortlistCredit {
  id                   String    @id @default(cuid())
  architect_profile_id String
  project_request_id   String
  credits_spent        Int       @default(1)
  price_paid_mad       Int       // Prix payé pour ce lead
  created_at           DateTime  @default(now()) @db.Timestamptz(6)

  @@unique([architect_profile_id, project_request_id])
  @@index([architect_profile_id])
  @@map("shortlist_credit")
}
