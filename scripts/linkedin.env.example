# Publer API Configuration for bati.ma LinkedIn automation
# Copy this file to scripts/linkedin.env and fill in your values
#
# Setup steps:
# 1. Create LinkedIn company page: linkedin.com/company/setup/new
# 2. Create Publer account: publer.com (free plan = 5 accounts)
# 3. Connect your LinkedIn page in Publer
# 4. Generate API key: Publer Settings → Access & Login → API Keys
#    Scopes needed: workspaces, accounts, posts, media
# 5. Run: node scripts/linkedin-autoposter.mjs --setup
# 6. Copy the IDs below

PUBLER_API_KEY=
PUBLER_WORKSPACE_ID=
PUBLER_LINKEDIN_ACCOUNT_ID=

# Optional: bati.ma API URL (defaults to https://api.bati.ma)
# BATI_API_URL=http://localhost:3001
